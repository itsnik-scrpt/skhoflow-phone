<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SkhoFlow.Host.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI">

    <ScrollViewer Style="{StaticResource PageRootStyle}">
        <StackPanel Spacing="20" MaxWidth="980" HorizontalAlignment="Stretch">

            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource LabelStyle}" Text="SETTINGS" />
                <TextBlock Style="{StaticResource PageHeadlineStyle}" Text="Tune your stream" />
                <TextBlock Style="{StaticResource SubtitleStyle}"
                           Text="Resolution, codec, network. Changes save automatically." />
            </StackPanel>

            <!-- Video section -->
            <tk:SettingsCard Header="Resolution"
                             Description="Output dimensions encoded and sent to the iPhone."
                             HeaderIcon="{ui:FontIcon Glyph=&#xEC4A;}">
                <ComboBox x:Name="ResolutionCombo" SelectionChanged="Resolution_Changed" MinWidth="200">
                    <ComboBoxItem Content="720p (1280x720)" Tag="720" />
                    <ComboBoxItem Content="1080p (1920x1080)" Tag="1080" IsSelected="True" />
                    <ComboBoxItem Content="1440p (2560x1440)" Tag="1440" />
                    <ComboBoxItem Content="2160p (3840x2160)" Tag="2160" />
                </ComboBox>
            </tk:SettingsCard>

            <tk:SettingsCard Header="Frame rate"
                             Description="Higher is smoother, costs more bandwidth and battery.">
                <ComboBox x:Name="FpsCombo" SelectionChanged="Fps_Changed" MinWidth="200">
                    <ComboBoxItem Content="30 fps" Tag="30" />
                    <ComboBoxItem Content="60 fps" Tag="60" IsSelected="True" />
                    <ComboBoxItem Content="90 fps" Tag="90" />
                    <ComboBoxItem Content="120 fps" Tag="120" />
                </ComboBox>
            </tk:SettingsCard>

            <tk:SettingsCard Header="Bitrate"
                             Description="Target Mbps. iPhone displays cap around 25 Mbps over Wi-Fi 6.">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Slider x:Name="BitrateSlider"
                            Minimum="3" Maximum="60"
                            Value="20"
                            StepFrequency="1"
                            Width="260"
                            ValueChanged="Bitrate_Changed" />
                    <TextBlock x:Name="BitrateValueText"
                               Text="20 Mbps"
                               MinWidth="80"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </tk:SettingsCard>

            <tk:SettingsCard Header="Codec"
                             Description="H.265 ~30% better quality at the same bitrate where supported.">
                <ComboBox x:Name="CodecCombo" SelectionChanged="Codec_Changed" MinWidth="200">
                    <ComboBoxItem Content="H.264" Tag="H264" IsSelected="True" />
                    <ComboBoxItem Content="H.265 / HEVC" Tag="H265" />
                </ComboBox>
            </tk:SettingsCard>

            <tk:SettingsCard Header="Hardware encoder"
                             Description="Auto picks NVENC, AMF or QuickSync based on your GPU.">
                <ComboBox x:Name="EncoderCombo" SelectionChanged="Encoder_Changed" MinWidth="200">
                    <ComboBoxItem Content="Auto" Tag="Auto" IsSelected="True" />
                    <ComboBoxItem Content="NVIDIA NVENC" Tag="NVENC" />
                    <ComboBoxItem Content="AMD AMF" Tag="AMF" />
                    <ComboBoxItem Content="Intel QuickSync" Tag="QuickSync" />
                    <ComboBoxItem Content="Software (x264)" Tag="Software" />
                </ComboBox>
            </tk:SettingsCard>

            <!-- Audio -->
            <TextBlock Style="{StaticResource LabelStyle}" Text="AUDIO" Margin="0,12,0,0" />

            <tk:SettingsCard Header="Stream audio"
                             Description="Capture system audio over WASAPI loopback and stream as Opus.">
                <ToggleSwitch x:Name="AudioToggle" Toggled="Audio_Toggled" IsOn="True" />
            </tk:SettingsCard>

            <!-- Security -->
            <TextBlock Style="{StaticResource LabelStyle}" Text="SECURITY" Margin="0,12,0,0" />

            <tk:SettingsCard Header="Require PIN to pair"
                             Description="6-digit one-time code shown in the app and entered on the iPhone.">
                <ToggleSwitch x:Name="PinToggle" Toggled="Pin_Toggled" IsOn="True" />
            </tk:SettingsCard>

            <tk:SettingsCard Header="Host name"
                             Description="The name your iPhone sees when picking a host.">
                <TextBox x:Name="HostNameTextBox"
                         MinWidth="240"
                         TextChanged="HostName_Changed" />
            </tk:SettingsCard>

            <!-- Network -->
            <TextBlock Style="{StaticResource LabelStyle}" Text="NETWORK" Margin="0,12,0,0" />

            <tk:SettingsCard Header="Control port"
                             Description="HTTP port for pairing + session control.">
                <NumberBox x:Name="ControlPortBox"
                           Minimum="1024" Maximum="65535"
                           Value="47990"
                           SpinButtonPlacementMode="Inline"
                           ValueChanged="ControlPort_Changed"
                           MinWidth="160" />
            </tk:SettingsCard>

            <tk:SettingsCard Header="Video port"
                             Description="UDP port carrying the H.264/H.265 RTP stream.">
                <NumberBox x:Name="VideoPortBox"
                           Minimum="1024" Maximum="65535"
                           Value="47989"
                           SpinButtonPlacementMode="Inline"
                           ValueChanged="VideoPort_Changed"
                           MinWidth="160" />
            </tk:SettingsCard>

            <!-- App -->
            <TextBlock Style="{StaticResource LabelStyle}" Text="APP" Margin="0,12,0,0" />

            <tk:SettingsCard Header="Start with Windows"
                             Description="Launch SkhoFlow when you sign in.">
                <ToggleSwitch x:Name="AutostartToggle" Toggled="Autostart_Toggled" />
            </tk:SettingsCard>

            <tk:SettingsCard Header="Minimize to tray"
                             Description="Closing the window keeps SkhoFlow running in the notification area.">
                <ToggleSwitch x:Name="TrayToggle" Toggled="Tray_Toggled" IsOn="True" />
            </tk:SettingsCard>

            <tk:SettingsCard Header="About"
                             Description="SkhoFlow 2.0 · build 2026.05 · MIT-licensed dependencies"
                             HeaderIcon="{ui:FontIcon Glyph=&#xE946;}" />

        </StackPanel>
    </ScrollViewer>
</Page>
