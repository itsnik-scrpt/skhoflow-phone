<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SkhoFlow.Host.Pages.DevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:SkhoFlow.Host.Models">

    <ScrollViewer Style="{StaticResource PageRootStyle}">
        <StackPanel Spacing="20" MaxWidth="1100" HorizontalAlignment="Stretch">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Style="{StaticResource LabelStyle}" Text="DEVICES" />
                    <TextBlock Style="{StaticResource PageHeadlineStyle}" Text="Paired iPhones" />
                    <TextBlock Style="{StaticResource SubtitleStyle}"
                               Text="Manage trusted clients. Pair once, stream forever." />
                </StackPanel>

                <Button Grid.Column="1" VerticalAlignment="Bottom"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="PairNew_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontFamily="{StaticResource SymbolFont}" FontSize="14" />
                        <TextBlock Text="Pair new device" />
                    </StackPanel>
                </Button>
            </Grid>

            <ItemsControl x:Name="DevicesList" Margin="0,8,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="12" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:PairedDevice">
                        <Border Style="{StaticResource GlassCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="48" Height="48"
                                        CornerRadius="14"
                                        Background="{StaticResource Black700Brush}"
                                        BorderBrush="{StaticResource GlassStrokeBrush}"
                                        BorderThickness="1"
                                        Margin="0,0,16,0">
                                    <FontIcon Glyph="&#xE8EA;"
                                              FontFamily="{StaticResource SymbolFont}"
                                              FontSize="22"
                                              Foreground="{StaticResource AccentBrush}" />
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                                    <TextBlock Text="{x:Bind Name}"
                                               FontSize="16" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="{x:Bind Model}"
                                               Style="{StaticResource SubtitleStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            VerticalAlignment="Center" Spacing="6">
                                    <Button Style="{StaticResource IconButtonStyle}"
                                            ToolTipService.ToolTip="Remove"
                                            Tag="{x:Bind Id}"
                                            Click="RemoveDevice_Click">
                                        <FontIcon Glyph="&#xE74D;" FontFamily="{StaticResource SymbolFont}" FontSize="14" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Empty state -->
            <Border x:Name="EmptyState" Style="{StaticResource GlassCardLowStyle}" Padding="40">
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <Border Width="64" Height="64" CornerRadius="20"
                            Background="{StaticResource Black700Brush}"
                            BorderBrush="{StaticResource GlassStrokeBrush}" BorderThickness="1">
                        <FontIcon Glyph="&#xE8EA;"
                                  FontFamily="{StaticResource SymbolFont}"
                                  FontSize="28"
                                  Foreground="{StaticResource AccentBrush}" />
                    </Border>
                    <TextBlock Style="{StaticResource TitleStyle}" Text="No devices yet"
                               HorizontalAlignment="Center" />
                    <TextBlock Style="{StaticResource SubtitleStyle}"
                               Text="Pair your iPhone to start streaming."
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
