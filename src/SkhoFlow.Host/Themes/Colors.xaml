<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- SkhoFlow palette: matte black, crimson, hot red -->
    <Color x:Key="BlackPure">#FF000000</Color>
    <Color x:Key="Black900">#FF0A0A0A</Color>
    <Color x:Key="Black800">#FF111114</Color>
    <Color x:Key="Black700">#FF181820</Color>
    <Color x:Key="Black600">#FF24242E</Color>
    <Color x:Key="Black500">#FF2E2E38</Color>

    <Color x:Key="AccentCrimson">#FFE11D2A</Color>
    <Color x:Key="AccentRed">#FFFF2937</Color>
    <Color x:Key="AccentDeep">#FF8A0612</Color>
    <Color x:Key="AccentMuted">#FF4D0610</Color>
    <Color x:Key="AccentGlow">#66FF2937</Color>

    <Color x:Key="TextPrimary">#FFFFFFFF</Color>
    <Color x:Key="TextSecondary">#FFB8B8C2</Color>
    <Color x:Key="TextTertiary">#FF6E6E78</Color>

    <Color x:Key="GlassStroke">#1AFFFFFF</Color>
    <Color x:Key="GlassStrokeStrong">#33FFFFFF</Color>
    <Color x:Key="GlassStrokeAccent">#66E11D2A</Color>

    <!-- Solid brushes -->
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource BlackPure}" />
    <SolidColorBrush x:Key="Black900Brush" Color="{StaticResource Black900}" />
    <SolidColorBrush x:Key="Black800Brush" Color="{StaticResource Black800}" />
    <SolidColorBrush x:Key="Black700Brush" Color="{StaticResource Black700}" />
    <SolidColorBrush x:Key="Black600Brush" Color="{StaticResource Black600}" />

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentCrimson}" />
    <SolidColorBrush x:Key="AccentHotBrush" Color="{StaticResource AccentRed}" />
    <SolidColorBrush x:Key="AccentDeepBrush" Color="{StaticResource AccentDeep}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiary}" />

    <SolidColorBrush x:Key="GlassStrokeBrush" Color="{StaticResource GlassStroke}" />
    <SolidColorBrush x:Key="GlassStrokeStrongBrush" Color="{StaticResource GlassStrokeStrong}" />
    <SolidColorBrush x:Key="GlassStrokeAccentBrush" Color="{StaticResource GlassStrokeAccent}" />

    <!-- Glass surfaces: layered translucency over Mica backdrop -->
    <SolidColorBrush x:Key="GlassSurfaceLow" Color="#14FFFFFF" />
    <SolidColorBrush x:Key="GlassSurface" Color="#1FFFFFFF" />
    <SolidColorBrush x:Key="GlassSurfaceHigh" Color="#2EFFFFFF" />
    <SolidColorBrush x:Key="GlassSurfaceHover" Color="#33FFFFFF" />

    <!-- Accent gradient (crimson → hot red) for primary actions and the brand mark -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AccentCrimson}" Offset="0" />
        <GradientStop Color="{StaticResource AccentRed}" Offset="1" />
    </LinearGradientBrush>

    <!-- Subtle red->black gradient for hero panels -->
    <LinearGradientBrush x:Key="HeroGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#33E11D2A" Offset="0" />
        <GradientStop Color="#000A0A0A" Offset="0.85" />
    </LinearGradientBrush>

    <!-- Radial accent glow for hero/CTA backgrounds -->
    <RadialGradientBrush x:Key="AccentGlowBrush"
                         Center="0.5,0.5"
                         RadiusX="0.7" RadiusY="0.7"
                         GradientOrigin="0.5,0.5">
        <GradientStop Color="#66E11D2A" Offset="0" />
        <GradientStop Color="#00E11D2A" Offset="1" />
    </RadialGradientBrush>

</ResourceDictionary>
